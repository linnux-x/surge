#!name=VPS Monitor
#!desc=实时查看 VPS 状态：内存 CPU 硬盘 流量 IP。长按编辑填写 Token
#!category=📊 ▸ Monitor
#!arguments=TOKEN:access_token

[Panel]
VPS-Status = icon="server.rack",icon-color="#58A6FF",script-name=vps-panel

[Rule]
# 端口级规则确保 VPS Monitor 直连
DEST-PORT,8765,DIRECT

[Script]
vps-panel = type=generic,timeout=10,script-path=https://raw.githubusercontent.com/linnux-x/surge/4232bc4/scripts/vps_monitor_panel.js,argument=token={{{TOKEN}}}
