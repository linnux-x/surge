# NAME: WeChat
# AUTHOR: Codex
# UPDATED: 2026-06-13
# FORMAT: Surge Ruleset
# SOURCES: WeChat and Weixin services, NobyDa/Script, ACL4SSR, blackmatrix7/ios_rule_script
# NOTE: Consumer WeChat and Weixin on iPhone and Mac, including login, messaging, media, Mini Programs, location and payments. Broad Tencent ASN and carrier ranges are excluded.

# WeChat and Weixin dedicated hosts
DOMAIN,apd-pcdnwxlogin.teg.tencent-cloud.net
DOMAIN,dldir1.qq.com
DOMAIN,vweixinf.tc.qq.com
DOMAIN,weixin110.qq.com

# Device positioning hosts used by WeChat
DOMAIN,apis.map.qq.com
DOMAIN,cc.map.qq.com
DOMAIN,indoorroad.map.qq.com
DOMAIN,lbs.map.qq.com
DOMAIN,nlp.map.qq.com
DOMAIN,rttgps.map.qq.com
DOMAIN,ue.indoorloc.map.qq.com

# Core WeChat and Weixin domains
DOMAIN-SUFFIX,wechat.com
DOMAIN-SUFFIX,wechatlegal.net
DOMAIN-SUFFIX,wechatos.net
DOMAIN-SUFFIX,weixin.com
DOMAIN-SUFFIX,weixin.qq.com
DOMAIN-SUFFIX,weixinbridge.com
DOMAIN-SUFFIX,weixinsxy.com
DOMAIN-SUFFIX,wx.qq.com
DOMAIN-SUFFIX,wxs.qq.com

# Mini Programs, payments, media and location
DOMAIN-SUFFIX,lbs.gtimg.com
DOMAIN-SUFFIX,qlogo.cn
DOMAIN-SUFFIX,qpic.cn
DOMAIN-SUFFIX,servicewechat.com
DOMAIN-SUFFIX,tenpay.com
DOMAIN-SUFFIX,up-hl.3g.qq.com
DOMAIN-SUFFIX,vweixinthumb.tc.qq.com
DOMAIN-SUFFIX,wechatpay.com
DOMAIN-SUFFIX,wx.gtimg.com
DOMAIN-SUFFIX,wxapp.tc.qq.com
DOMAIN-SUFFIX,yun-hl.3g.qq.com

# Client fallbacks: HTTP/HTTPS on both platforms, process matching on Mac only
USER-AGENT,MicroMessenger*
USER-AGENT,WeChat*
PROCESS-NAME,WeChat
